{
    "embed_dim": 768,
    "custom_text": true,
    "vision_cfg": {
        "image_size": 448,
        "timm_model_name": "vit_base_patch14_reg1_tipsv2",
        "timm_model_pretrained": false,
        "timm_pool": "token",
        "timm_proj": "none"
    },
    "text_cfg": {
        "context_length": 64,
        "vocab_size": 32000,
        "hf_tokenizer_name": "tips",
        "tokenizer_mode": "tips",
