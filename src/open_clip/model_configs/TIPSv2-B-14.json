        "heads": 12,
        "layers": 12,
        "mlp_ratio": 4.0,
        "no_causal_mask": true,
        "use_pad_mask": true,
        "pad_id": 0,
        "pool_type": "mean",
        "pos_embed_type": "sinusoidal",
        "scale_sqrt_depth": true,
        "proj_type": "none",
        "act_layer": "relu"
    }
